# =============================================================================
# papers_unir — .gitignore
# =============================================================================

# --- OS & editor -----------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.idea/
*.sublime-project
*.sublime-workspace

# --- Credentials & secrets -------------------------------------------------
.env
.env.*
!.env.example
*.key
*.pem
credentials.json
secrets/

# --- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
/build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/
.python-version

# Testing & linting caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- LaTeX -----------------------------------------------------------------
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.log
*.lot
*.out
*.run.xml
*.synctex.gz
*.toc
*.xdv
*.nav
*.snm
*.vrb
*.synctex(busy)

# Paper build outputs (keep source; ignore compiled artifacts)
papers/**/build/*
!papers/**/build/.gitkeep
papers/**/drafts/*.pdf

# PDFs elsewhere (allow committed figure exports if explicitly added)
*.pdf
!figures/export/.gitkeep

# --- Large datasets (raw & processed) --------------------------------------
# Ignore dataset contents by default; allow documentation placeholders.
data/raw/*
!data/raw/.gitkeep
!data/raw/README.md

data/processed/*
!data/processed/.gitkeep
!data/processed/README.md

data/intermediate/*
!data/intermediate/.gitkeep
!data/intermediate/README.md

data/external/*
!data/external/.gitkeep
!data/external/README.md

# Large binary / serialized formats (anywhere in repo)
*.parquet
*.feather
*.h5
*.hdf5
*.pkl
*.pickle
*.joblib
*.npz
*.npy
*.sqlite
*.sqlite3
*.db

# CSV in raw/processed only (small CSVs allowed elsewhere, e.g. results/metrics/)
data/raw/**/*.csv
data/processed/**/*.csv

# Large result artifacts
results/models/*
!results/models/.gitkeep
!results/models/README.md

results/logs/*
!results/logs/.gitkeep

# --- Temporary & cache files -----------------------------------------------
tmp/
temp/
*.tmp
*.temp
.cache/
*.bak

# --- Zenodo release bundles (generated locally) ------------------------------
zenodo/releases/**/bundle/
zenodo/releases/**/*.zip
