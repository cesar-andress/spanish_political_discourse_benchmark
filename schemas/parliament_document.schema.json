{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spdb.unir.net/schemas/parliament_document.schema.json",
  "title": "SPDB parliament document (intermediate)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_id",
    "source_type",
    "source_name",
    "date",
    "speaker_name",
    "speaker_party",
    "language",
    "text"
  ],
  "properties": {
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "enum": ["parliamentary"]
    },
    "source_name": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "speaker_name": {
      "type": "string",
      "minLength": 1
    },
    "speaker_party": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z]{2}$"
    },
    "text": {
      "type": "string",
      "minLength": 1
    }
  }
}
